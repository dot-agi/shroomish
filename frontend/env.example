# =============================================================================
# Clerk Authentication (Required)
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk JWT template for backend auth
CLERK_JWT_TEMPLATE=oddish

# =============================================================================
# Backend API
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# Optional App & Clerk Redirect Overrides
# =============================================================================
# App base URL for absolute Clerk redirects (useful for local HTTPS flows)
# NEXT_PUBLIC_APP_URL=https://local.oddish.app
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# =============================================================================
# Observability (Pydantic Logfire) - opt-in only
# =============================================================================
# Browser SDK is OFF unless a token is set. The token is bundled into
# client JS — use a Logfire write-only project token, NOT the server's
# `LOGFIRE_TOKEN`.
# NEXT_PUBLIC_LOGFIRE_TOKEN=pylf_...
# NEXT_PUBLIC_LOGFIRE_ENVIRONMENT=production     # override auto-detect
# NEXT_PUBLIC_APP_VERSION=$VERCEL_GIT_COMMIT_SHA # tag spans with a release
#
# Server-side (Next.js API routes / SSR) tracing goes through
# `@vercel/otel` and ships spans DIRECTLY to Logfire over OTLP. Set
# the server-only write token (do NOT prefix with `NEXT_PUBLIC_`):
# LOGFIRE_TOKEN=pylf_...
# LOGFIRE_OTLP_ENDPOINT=https://logfire-api.pydantic.dev/v1/traces  # optional override
# LOGFIRE_ENVIRONMENT=prod                       # optional override
